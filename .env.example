# Copy to .env and fill in your values:  cp .env.example .env
# .env is gitignored. The launcher scripts auto-source it, and Weights & Biases
# reads WANDB_API_KEY from the environment, so no interactive `wandb login` is needed.

# Required for W&B logging (https://wandb.ai/authorize)
WANDB_API_KEY=

# Hugging Face token for gated models like meta-llama/* (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Git identity — re-applied by setup each session (container ~/.gitconfig is ephemeral).
# Quote values containing spaces.
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL=you@example.com

# Optional W&B defaults
# WANDB_ENTITY=your-team-or-username
# WANDB_PROJECT=efficient_sae
# Use WANDB_MODE=offline to log locally without a network/account.
# WANDB_MODE=online
